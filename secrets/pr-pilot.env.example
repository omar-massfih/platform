# Copy to pr-pilot.env and pr-pilot-omarmassfih.env, fill in per instance.
# Creates k8s Secrets `pr-pilot` and `pr-pilot-omarmassfih`.

TELEGRAM_BOT_TOKEN=
# GitHub token used by `gh`/`git push` inside the pod (write access to target repos)
GH_TOKEN=
# git identity for commits made by the bot
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
